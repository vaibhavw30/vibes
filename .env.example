# ─────────────────────────────────────────────────────────────────────────────
# Environment variables for vaibhavwudaru.com
# Copy to `.env.local` and fill in. NEVER commit real secrets.
# All secrets are read SERVER-SIDE only (route handlers / server components).
# Only NEXT_PUBLIC_* values are exposed to the browser.
# ─────────────────────────────────────────────────────────────────────────────

# Public site URL — used for metadataBase, OG tags, sitemap.
NEXT_PUBLIC_SITE_URL=https://vaibhavwudaru.com

# ── Letterboxd (High priority) ───────────────────────────────────────────────
# No auth. Public RSS feed parsed at build/ISR. Powers /about/movies + home breadcrumb.
# Defaults to "vaibzz" if unset. NOTE: Letterboxd 403s a default fetcher UA — the
# server fetch sends a browser User-Agent (see src/lib/letterboxd.ts).
LETTERBOXD_USERNAME=

# ── Chess.com (High priority) ────────────────────────────────────────────────
# No auth. Public API: api.chess.com/pub/player/USERNAME. Powers /about/chess
# (live ratings + recent games) and the corrected home carousel stat.
# Defaults to "nemoblob" if unset. The server fetch sends a browser User-Agent
# (same convention as Letterboxd; see src/lib/chess.ts).
CHESSCOM_USERNAME=
# (Optional alt if he plays there instead)
# LICHESS_USERNAME=

# ── YouTube (High priority — PLACEHOLDERS for now) ────────────────────────────
# YouTube Data API v3 key. No videos recorded yet — wire real IDs later.
YOUTUBE_API_KEY=
# Optional: default channel/playlist to pull demos from once recorded.
# YOUTUBE_CHANNEL_ID=

# ── Spotify (Medium priority) ────────────────────────────────────────────────
# Web API — OAuth with a long-lived refresh token, refreshed SERVER-SIDE only.
# Powers the /now listening line (currently-playing → recently-played fallback).
# One-time setup: create an app at developer.spotify.com/dashboard, add redirect
# URI http://127.0.0.1:8888/callback, then run:
#   SPOTIFY_CLIENT_ID=… SPOTIFY_CLIENT_SECRET=… node scripts/spotify-auth.mjs
# and paste the three values it prints below. Until then /now shows a snapshot.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# ── Fitbit + Upstash (Medium priority) ───────────────────────────────────────
# Powers the "Staying active" feed (weekly sessions + time) on /now, the home hero,
# and /about/training. Server-side only. Fitbit rotates its refresh token on every
# refresh, so the rotating token is persisted in Upstash Redis (a static env var
# can't hold it); FITBIT_REFRESH_TOKEN is only the SEED for the first refresh.
# NOTE: the Fitbit Web API is deprecating in Sept 2026 — this is a known interim
# source; the plan is to swap the provider (src/lib/activity.ts) to the Google
# Health API then. Until any of this is set, the surfaces read "a quiet week".
#
# Fitbit setup: dev.fitbit.com → Register an app (type: Personal, callback
# http://127.0.0.1:8888/callback, Read Only), then:
#   FITBIT_CLIENT_ID=… FITBIT_CLIENT_SECRET=… node scripts/fitbit-auth.mjs
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
FITBIT_REFRESH_TOKEN=
# Upstash setup: console.upstash.com → create a free Redis DB → copy the REST URL
# and REST token (the token store for Fitbit's rotating refresh token).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Recipes (Medium priority) ────────────────────────────────────────────────
# No keys — images live in-repo (e.g. /public/recipes). Nothing to configure here.

# ── ESPN Fantasy (STRETCH — do NOT build the brittle integration) ─────────────
# Unofficial API needs a league cookie and is fragile. Represent fantasy football
# as an interest instead. Left here only to document intent; leave unset.
# ESPN_S2=
# ESPN_SWID=
# ESPN_LEAGUE_ID=
